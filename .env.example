# Required for live posting
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional for pin/unpin actions (recommended user token with pages_manage_engagement)
# PIN_ACCESS_TOKEN=
# FACEBOOK_USER_ACCESS_TOKEN=

# AI provider: gemini | deepseek | openai
AI_PROVIDER=gemini
# 1 => AI fail бол fallback post хийхгүй, тухайн run алдаа өгөөд зогсоно
REQUIRE_AI_CONTENT=1
# Optional uniqueness seed override (ихэнхдээ хоосон байлгана)
# POST_VARIATION_SEED=

# DeepSeek (optional alternative)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SEC=90
DEEPSEEK_MAX_TOKENS=1400
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Gemini (default provider)
GEMINI_API_KEY=
# Multiple keys (comma-separated) for round-robin + failover
# GEMINI_API_KEYS=key1,key2
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI (optional alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini failure alerts
ALERT_ON_GEMINI_FAILURE=1
# DRY_RUN үед ч alert илгээх бол 1
ALERT_ON_DRY_RUN=0
# Optional generic webhook (Slack/Discord/Make гэх мэт)
ALERT_WEBHOOK_URL=
# Optional Telegram alert
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Optional
MAX_ITEMS=5
MAX_ITEM_AGE_HOURS=12
# Content timezone for schedule-based posting
CONTENT_TIMEZONE=Asia/Ulaanbaatar
# 1 => use fixed hourly category map (06,08,14,18,22)
USE_TIME_SLOT_SCHEDULE=1
# 1 => midnight "goodnight" post enabled when a 00:00 slot exists
ENABLE_MIDNIGHT_POST=1

# Optional category override:
# insight | horoscope | zodiac_horoscope | mantra | fact | weekly | weekly_horoscope
# daily_guidance | messenger_cta | evening_insight | tomorrow_prep | goodnight
# Backward compatibility: `news` -> `insight`
POST_CATEGORY=
# Testing helper: force schedule hour (0-23), e.g. FORCE_SLOT_HOUR=8
# FORCE_SLOT_HOUR=
# Rotation order when POST_CATEGORY is empty
AUTO_CATEGORIES=insight,horoscope,mantra,fact
# Pin controls
# PIN_POST=1 => whichever post was created this run becomes pinned
PIN_POST=0
# Time-slot pin controls (default: pin 06:00 and 08:00 horoscope posts)
PIN_SCHEDULED_POSTS=1
PIN_CATEGORIES=horoscope,zodiac_horoscope
# Weekly category дээр default-аар pin хийнэ
PIN_WEEKLY_POST=1
# Weekly pin rotation:
# шинэ weekly post pin болохын өмнө өмнөх weekly pinned post-ыг unpin хийхийг оролдоно
DRY_RUN=1
